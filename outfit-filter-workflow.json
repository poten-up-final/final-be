            },
            {
              "name": "aiComment",
              "value": "={{$json.text.split(\"aiComment\\\": \\\"\")[1].split(\"\\\"\")[0]}}"
            }
          ]
        },
        "options": {}
      },
      "id": "set-result",
      "name": "Set Result",
