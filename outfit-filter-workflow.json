      ],
      "webhookId": "82aae4fc-e009-4e6a-95f1-ffcd45b75f2f"
    },
    {
      "parameters": {
        "url": "={{$node[\"Webhook\"].json.body.imageUrl.trim()}}",
        "options": {},
        "responseFormat": "file"
      },
      "id": "download-image",
      "name": "HTTP Request (Image Download)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        208,
        0
      ]
    },
    {
      "parameters": {
        "mode": "manual",
        "values": {
          "string": [
            {
              "name": "cardImageId",
              "value": "={{$node[\"Webhook\"].json.body.cardImageId}}"
